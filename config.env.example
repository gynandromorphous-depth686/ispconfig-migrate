# ispconfig-migrate configuration
# Copy this file to config.env and fill in your values
# Never commit config.env to git — it is in .gitignore

# ============================================================
# OLD SERVER
# ============================================================
OLD_SERVER_HOST="web2.yourdomain.nl"
OLD_SERVER_USER="your_ssh_user"
OLD_SERVER_PORT=22
OLD_MYSQL_ROOT_PASS="your_old_mysql_root_password"

# ============================================================
# NEW SERVER
# ============================================================
NEW_SERVER_HOST="37.97.157.168"
NEW_SERVER_USER="your_ssh_user"
NEW_SERVER_PORT=22
NEW_MYSQL_ROOT_PASS="your_new_mysql_root_password"

# ============================================================
# ISPCONFIG
# ============================================================
ISPCONFIG_URL="https://localhost:8080"
ISPCONFIG_REMOTE_USER="remoteapi"
ISPCONFIG_REMOTE_PASS="your_remote_api_password"
ISPCONFIG_SERVER_ID=1

# ============================================================
# GENERAL
# ============================================================
ADMIN_EMAIL="admin@yourdomain.nl"
HOSTING_PROVIDER="YourCompany"
